# Required
BOT_TOKEN=        # From @BotFather
API_ID=           # From my.telegram.org
API_HASH=         # From my.telegram.org
OWNER_ID=         # Your Telegram user ID
MONGODB_PASSWORD= # Your MongoDB Atlas password

# Required for search
SESSION_SECRET=   # Pyrogram user session string (generate at /gen on health server)

# Optional
LOG_CHANNEL=      # Channel ID for bot logs e.g. -100xxxxxxxxx
PORT=8080         # Health server port (Railway sets this automatically)
