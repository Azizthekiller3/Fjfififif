# ─────────────────────────────────────────
#  MovieBot — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Telegram credentials (required) ──────
BOT_TOKEN=        # From @BotFather  e.g. 123456:ABCdef...
API_ID=           # From https://my.telegram.org  (integer)
API_HASH=         # From https://my.telegram.org  (string)
OWNER_ID=         # Your Telegram numeric user ID (use @userinfobot)

# ── MongoDB (required) ───────────────────
# Option A — just your password (uses the built-in Atlas URI):
MONGODB_PASSWORD= # Atlas password for user abdulazizshaik521
# Option B — full custom URI (overrides MONGODB_PASSWORD):
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=MyApp

# ── User session for search (required) ───
# Pyrogram STRING session for a real Telegram account.
# Generate one by visiting  https://<your-host>/gen  after deploying,
# or use @StringSessionBot on Telegram.
SESSION_SECRET=   # starts with "BQE..." — keep this secret!

# ── Optional ─────────────────────────────
LOG_CHANNEL=      # Channel ID where bot posts start/stop logs  e.g. -100123456789
UPDATES_CHANNEL=  # Your public updates channel username  (default: codeflix_bots)
BACKUP_CHANNEL=   # Backup channel link shown in search results

# ── Server (auto-set by Railway / Render / Heroku) ───
PORT=8080         # Health-check server port; set automatically on most platforms
